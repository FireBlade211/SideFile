  <Application.Views>
    <Ribbon Name="Ribbon" GroupSpacing="Medium">
      <Ribbon.ApplicationMenu>
        <ApplicationMenu CommandName="ApplicationMenu">
          <ApplicationMenu.RecentItems>
            <RecentItems CommandName="RecentItemsCaption" />
          </ApplicationMenu.RecentItems>
          <MenuGroup>
            <Button CommandName="btnNewWindow" />
            <SplitButtonGallery CommandName="sbgCliHere" />
          </MenuGroup>
          <MenuGroup>
            <Button CommandName="btnSettings" />
            <SplitButton CommandName="sbAbout">
              <SplitButton.ButtonItem>
                <Button CommandName="btnAbout" />
              </SplitButton.ButtonItem>
              <SplitButton.MenuGroups>
                <MenuGroup CommandName="mngAbout" Class="MajorItems">
                  <Button CommandName="btnAbout" />
                  <Button CommandName="btnAboutWin" />
                </MenuGroup>
              </SplitButton.MenuGroups>
            </SplitButton>
          </MenuGroup>
          <MenuGroup>
            <Button CommandName="btnExit" />
          </MenuGroup>
        </ApplicationMenu>
      </Ribbon.ApplicationMenu>
      <Ribbon.HelpButton>
        <HelpButton CommandName="HelpButton" />
      </Ribbon.HelpButton>
      <Ribbon.QuickAccessToolbar>
        <QuickAccessToolbar CommandName="QAT" CustomizeCommandName="btnCustomizeQat">
          <QuickAccessToolbar.ApplicationDefaults>
            <Button CommandName="btnNewWindow" ApplicationDefaults.IsChecked="false" />
            <Button CommandName="btnRename" ApplicationDefaults.IsChecked="true" />
            <Button CommandName="btnDelete" ApplicationDefaults.IsChecked="true" />
            <Button CommandName="btnProperties" ApplicationDefaults.IsChecked="true" />
            <Button CommandName="btnOpen" ApplicationDefaults.IsChecked="false" />
          </QuickAccessToolbar.ApplicationDefaults>
        </QuickAccessToolbar>
      </Ribbon.QuickAccessToolbar>
      <Ribbon.ContextualTabs>
        <TabGroup CommandName="ctabPicTools">
          <Tab CommandName="tabPicture" />
        </TabGroup>
        <TabGroup CommandName="ctabImgTools">
          <Tab CommandName="tabDskImg" />
        </TabGroup>
        <TabGroup CommandName="ctabArchiveTools">
          <Tab CommandName="tabArchive" />
        </TabGroup>
        <TabGroup CommandName="ctabExeTools">
          <Tab CommandName="tabExe" />
        </TabGroup>
        <TabGroup CommandName="ctabScriptTools">
          <Tab CommandName="tabScript" />
        </TabGroup>
        <TabGroup CommandName="ctabDriveTools">
          <Tab CommandName="tabDrive" />
        </TabGroup>
        <TabGroup CommandName="ctabComputer">
          <Tab CommandName="tabThisPC" />
        </TabGroup>
      </Ribbon.ContextualTabs>
      <Ribbon.Tabs>
        <Tab CommandName="tabHome">
          <Tab.ScalingPolicy>
            <ScalingPolicy>
              <ScalingPolicy.IdealSizes>
                <Scale Group="grpClipboard" Size="Large" />
                <Scale Group="grpOperations" Size="Medium" />
                <Scale Group="grpNew" Size="Medium" />
              </ScalingPolicy.IdealSizes>
              <Scale Group="grpClipboard" Size="Medium" />
              <Scale Group="grpClipboard" Size="Small" />
              <Scale Group="grpClipboard" Size="Popup" />
              <Scale Group="grpOperations" Size="Small" />
              <Scale Group="grpOperations" Size="Popup" />
              <Scale Group="grpNew" Size="Small" />
              <Scale Group="grpNew" Size="Popup" />
            </ScalingPolicy>
          </Tab.ScalingPolicy>
          <Group CommandName="grpClipboard">
            <SizeDefinition>
              <ControlNameMap>
                <ControlNameDefinition Name="copy" />
                <ControlNameDefinition Name="paste" />
                <ControlNameDefinition Name="cut" />
                <ControlNameDefinition Name="copy_to" />
                <ControlNameDefinition Name="move_to" />
              </ControlNameMap>
              <GroupSizeDefinition Size="Large">
                <ControlSizeDefinition ImageSize="Large" ControlName="copy" />
                <ControlSizeDefinition ImageSize="Large" ControlName="paste" />
                <ColumnBreak />
                <ControlSizeDefinition ControlName="cut" />
                <ControlSizeDefinition ControlName="copy_to" />
                <ControlSizeDefinition ControlName="move_to" />
              </GroupSizeDefinition>
              <GroupSizeDefinition Size="Medium">
                <ControlSizeDefinition ImageSize="Large" ControlName="copy" />
                <ControlSizeDefinition ImageSize="Large" ControlName="paste" />
                <ColumnBreak />
                <ControlSizeDefinition IsLabelVisible="false" ControlName="cut" />
                <ControlSizeDefinition IsLabelVisible="false" ControlName="copy_to" />
                <ControlSizeDefinition IsLabelVisible="false" ControlName="move_to" />
              </GroupSizeDefinition>
              <GroupSizeDefinition Size="Small">
                <Row>
                  <ControlSizeDefinition IsLabelVisible="false" ControlName="copy" />
                  <ControlSizeDefinition IsLabelVisible="false" ControlName="paste" />
                </Row>
                <Row>
                  <ControlSizeDefinition IsLabelVisible="false" ControlName="copy_to" />
                  <ControlSizeDefinition IsLabelVisible="false" ControlName="move_to" />
                </Row>
                <ControlSizeDefinition IsLabelVisible="false" ControlName="cut" />
              </GroupSizeDefinition>
            </SizeDefinition>
            <SplitButton CommandName="sbCopy">
              <SplitButton.ButtonItem>
                <Button CommandName="btnCopy" />
              </SplitButton.ButtonItem>
              <Button CommandName="btnCopy" />
              <Button CommandName="btnCopyPath" />
            </SplitButton>
            <SplitButton CommandName="sbPaste">
              <SplitButton.ButtonItem>
                <Button CommandName="btnPaste" />
              </SplitButton.ButtonItem>
              <Button CommandName="btnPaste" />
              <Button CommandName="btnPasteLink" />
            </SplitButton>
            <Button CommandName="btnCut" />
            <SplitButtonGallery CommandName="sbgCopyTo">
              <SplitButtonGallery.MenuLayout>
                <VerticalMenuLayout />
              </SplitButtonGallery.MenuLayout>
              <SplitButtonGallery.MenuGroups>
                <MenuGroup>
                  <Button CommandName="btnBrowseCopyTo" />
                </MenuGroup>
              </SplitButtonGallery.MenuGroups>
            </SplitButtonGallery>
            <SplitButtonGallery CommandName="sbgMoveTo">
              <SplitButtonGallery.MenuLayout>
                <VerticalMenuLayout />
              </SplitButtonGallery.MenuLayout>
              <SplitButtonGallery.MenuGroups>
                <MenuGroup>
                  <Button CommandName="btnBrowseMoveTo" />
                </MenuGroup>
              </SplitButtonGallery.MenuGroups>
            </SplitButtonGallery>
          </Group>
          <Group CommandName="grpOperations" SizeDefinition="SixButtons">
            <Button CommandName="btnRename" />
            <SplitButton>
              <SplitButton.ButtonItem>
                <Button CommandName="btnDelete" />
              </SplitButton.ButtonItem>
              <SplitButton.MenuGroups>
                <MenuGroup>
                  <Button CommandName="btnDelete" />
                  <Button CommandName="btnPermDelete" />
                </MenuGroup>
                <MenuGroup>
                  <CheckBox CommandName="chbConfirmDelete" />
                  <Button CommandName="btnRecycleBin" />
                </MenuGroup>
              </SplitButton.MenuGroups>
            </SplitButton>
            <Button CommandName="btnProperties" />
            <Button CommandName="btnOpen" />
            <Button CommandName="btnRunAs" />
            <DropDownGallery CommandName="ddgRunOptions">
              <DropDownGallery.MenuLayout>
                <VerticalMenuLayout Gripper="None" />
              </DropDownGallery.MenuLayout>
              <DropDownGallery.MenuGroups>
                <MenuGroup>
                  <Button CommandName="btnOpenWith" />
                </MenuGroup>
              </DropDownGallery.MenuGroups>
            </DropDownGallery>
          </Group>
          <Group CommandName="grpNew" SizeDefinition="FourButtons">
            <Button CommandName="btnNewDir" />
            <Button CommandName="btnNewText" />
            <Button CommandName="btnNewShortcut" />
            <DropDownButton CommandName="ddbNewOptions">
              <MenuGroup CommandName="mngTextFiles">
                <Button CommandName="btnMkFTxt" />
                <Button CommandName="btnMkFMd" />
                <Button CommandName="btnMkFRtf" />
              </MenuGroup>
              <MenuGroup CommandName="mngConfFiles">
                <Button CommandName="btnMkFXml" />
                <Button CommandName="btnMkFJson" />
                <Button CommandName="btnMkFIni" />
              </MenuGroup>
              <MenuGroup CommandName="mngLinkFiles">
                <Button CommandName="btnMkFLnk" />
                <Button CommandName="btnMkFUrl" />
                <Button CommandName="btnMkFSl" />
              </MenuGroup>
              <MenuGroup CommandName="mngScriptFiles">
                <Button CommandName="btnMkFBat" />
                <Button CommandName="btnMkFCmd" />
                <Button CommandName="btnMkFPs1" />
                <Button CommandName="btnMkFSh" />
                <Button CommandName="btnMkFFCmd" />
              </MenuGroup>
              <MenuGroup CommandName="mngCodeFiles">
                <Button CommandName="btnMkFCs" />
                <Button CommandName="btnMkFCpp" />
                <Button CommandName="btnMkFC" />
                <Button CommandName="btnMkFPy" />
              </MenuGroup>
            </DropDownButton>
          </Group>
        </Tab>
        <Tab CommandName="tabBrowse">
          <Tab.ScalingPolicy>
            <ScalingPolicy>
              <ScalingPolicy.IdealSizes>
                <Scale Group="grpNavigation" Size="Large" />
                <Scale Group="grpPath" Size="Large" />
              </ScalingPolicy.IdealSizes>
              <Scale Group="grpNavigation" Size="Medium" />
              <Scale Group="grpNavigation" Size="Small" />
              <Scale Group="grpNavigation" Size="Popup" />
              <Scale Group="grpPath" Size="Medium" />
              <Scale Group="grpPath" Size="Popup" />
            </ScalingPolicy>
          </Tab.ScalingPolicy>
          <Group CommandName="grpNavigation" SizeDefinition="FourButtons">
            <Button CommandName="btnBack" />
            <Button CommandName="btnFwd" />
            <Button CommandName="btnUp" />
            <Button CommandName="btnThisPC" />
          </Group>
          <Group CommandName="grpPath" SizeDefinition="TwoButtons">
            <Button CommandName="btnGoToPath" />
            <Button CommandName="btnFind" />
          </Group>
        </Tab>
        <Tab CommandName="tabSecurity">
          <Group CommandName="grpPerms" SizeDefinition="TwoButtons">
            <Button CommandName="btnViewAcl" />
            <Button CommandName="btnEditAcl" />
          </Group>
        </Tab>
        <Tab CommandName="tabView" />
        <Tab CommandName="tabTools" />
      </Ribbon.Tabs>
    </Ribbon>
    <ContextPopup />
  </Application.Views>
</Application>
